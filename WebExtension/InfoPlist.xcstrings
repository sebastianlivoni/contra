    "NSHumanReadableDescription" : {
      "comment" : "Human readable description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktiverer frem- og tilbage-navigation for din mus sideknapper. Denne udvidelse gør det muligt for Contra at registrere klik på knap 4 og knap 5 på websider, hvilket giver problemfri historiknavigation i Safari med din tredjepartsmus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Enables back and forward navigation for your mouse's side buttons. This extension allows Contra to detect Button 4 and Button 5 clicks on web pages, bringing seamless history navigation to Safari with your third-party mouse."
          }
        }
      }
    }
  },
  "version" : "1.2"
